<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Golden and Silver Rectangles</title>
  <style>
    :root {
      --bg: #0e1116;
      --panel: #171c24;
      --panel-2: #1f2631;
      --text: #e9eef7;
      --muted: #a7b1c2;
      --accent: #8fb8ff;
      --accent-2: #f4c96b;
      --line: #2a3342;
      --good: #8ad6a2;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .wrap {
      max-width: 1320px;
      margin: 0 auto;
      padding: 20px;
      display: grid;
      grid-template-columns: 340px 1fr;
      gap: 20px;
    }

    .panel,
    .canvas-panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 16px;
    }

    h1 {
      font-size: 1.35rem;
      margin: 0 0 8px;
    }

    h2 {
      font-size: 1rem;
      margin: 0 0 8px;
    }

    p, label, .small, button, select, input {
      font-size: 0.95rem;
    }

    .muted {
      color: var(--muted);
      line-height: 1.45;
    }

    .controls {
      display: grid;
      gap: 14px;
    }

    .control-block {
      background: var(--panel-2);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px;
    }

    .row {
      display: grid;
      gap: 8px;
      margin-bottom: 10px;
    }

    .row:last-child { margin-bottom: 0; }

    .inline {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    input[type="range"] {
      width: 100%;
    }

    select,
    button,
    input[type="number"] {
      background: #0f141b;
      color: var(--text);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 10px 12px;
    }

    button {
      cursor: pointer;
      transition: transform 0.08s ease, background 0.15s ease;
    }

    button:hover { background: #222c39; }
    button:active { transform: translateY(1px); }

    .button-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .canvas-panel {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .canvas-wrap {
      background: #0a0e14;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 10px;
    }

    canvas {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 10px;
      background: #05080d;
    }

    .readout {
      display: grid;
      grid-template-columns: repeat(4, minmax(140px, 1fr));
      gap: 10px;
    }

    .pill {
      background: var(--panel-2);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 10px 12px;
    }

    .pill strong {
      display: block;
      font-size: 0.82rem;
      color: var(--muted);
      margin-bottom: 4px;
      font-weight: 600;
    }

    .formula {
      font-family: "Times New Roman", Times, serif;
      font-size: 1rem;
      line-height: 1.5;
      color: var(--accent-2);
    }

    .footer-note {
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.45;
    }

    .legend {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .swatch {
      display: inline-block;
      width: 14px;
      height: 14px;
      border-radius: 4px;
      margin-right: 6px;
      vertical-align: middle;
    }

    .note-box {
      background: #0f141b;
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px;
      line-height: 1.5;
      color: var(--muted);
    }

    @media (max-width: 980px) {
      .wrap {
        grid-template-columns: 1fr;
      }

      .readout {
        grid-template-columns: repeat(2, minmax(140px, 1fr));
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="panel controls">
      <div>
        <h1>Golden and silver rectangles</h1>
        <p class="muted">
          This focuses on the rectangle itself. The point is not the initial triangle construction,
          but the way a rectangle of the right proportion reproduces its own shape under a simple cut.
          For the golden rectangle that cut removes one square. For the silver rectangle it removes two equal squares.
        </p>
      </div>

      <div class="control-block">
        <div class="row">
          <label for="family">Rectangle family</label>
          <select id="family">
            <option value="golden">Golden rectangle</option>
            <option value="silver">Silver rectangle</option>
            <option value="compare">Compare both</option>
          </select>
        </div>

        <div class="row">
          <label for="baseWidth">Base width: <span id="baseWidthLabel">260</span></label>
          <input id="baseWidth" type="range" min="120" max="420" step="1" value="260" />
        </div>

        <div class="row">
          <label for="levels">Subdivision depth: <span id="levelsLabel">6</span></label>
          <input id="levels" type="range" min="1" max="10" step="1" value="6" />
        </div>

        <div class="row">
          <label for="showGuides">Guides</label>
          <select id="showGuides">
            <option value="on">Show cut lines and labels</option>
            <option value="off">Hide guides</option>
          </select>
        </div>

        <div class="row">
          <label for="showTrace">Overlay trace</label>
          <select id="showTrace">
            <option value="on">Show trace</option>
            <option value="off">Hide trace</option>
          </select>
        </div>
      </div>

      <div class="control-block">
        <h2>What remains similar?</h2>
        <div class="note-box" id="explanationBox"></div>
      </div>

      <div class="control-block">
        <div class="formula" id="formulaBox"></div>
      </div>

      <div class="control-block">
        <div class="button-row">
          <button id="stepBtn">Advance one cut</button>
          <button id="resetBtn">Reset depth</button>
          <button id="downloadBtn">Download PNG</button>
        </div>
      </div>

      <div class="footer-note">
        The golden case satisfies φ = 1 + 1/φ, so subtracting one square leaves a smaller similar rectangle.
        The silver case satisfies δ = 2 + 1/δ, so subtracting two adjacent squares leaves a smaller similar rectangle.
      </div>
    </section>

    <section class="canvas-panel">
      <div class="readout">
        <div class="pill">
          <strong>Ratio</strong>
          <span id="ratioReadout">φ ≈ 1.618034</span>
        </div>
        <div class="pill">
          <strong>Self-similarity rule</strong>
          <span id="ruleReadout">R = 1 + 1/R</span>
        </div>
        <div class="pill">
          <strong>Cut used</strong>
          <span id="cutReadout">Remove 1 square</span>
        </div>
        <div class="pill">
          <strong>Remaining scale</strong>
          <span id="scaleReadout">1/φ ≈ 0.618034</span>
        </div>
      </div>

      <div class="legend">
        <span><span class="swatch" style="background:#f4c96b"></span>removed square block(s)</span>
        <span><span class="swatch" style="background:#8fb8ff"></span>remaining similar rectangle</span>
        <span><span class="swatch" style="background:#8ad6a2"></span>trace</span>
      </div>

      <div class="canvas-wrap">
        <canvas id="canvas" width="920" height="760"></canvas>
      </div>

      <div class="footer-note" id="captionBox">
        A ratio is special here when the same cut can be repeated indefinitely and the shape survives, merely reduced.
      </div>
    </section>
  </div>

  <script>
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');

    const familyEl = document.getElementById('family');
    const baseWidthEl = document.getElementById('baseWidth');
    const levelsEl = document.getElementById('levels');
    const showGuidesEl = document.getElementById('showGuides');
    const showTraceEl = document.getElementById('showTrace');

    const baseWidthLabel = document.getElementById('baseWidthLabel');
    const levelsLabel = document.getElementById('levelsLabel');

    const ratioReadout = document.getElementById('ratioReadout');
    const ruleReadout = document.getElementById('ruleReadout');
    const cutReadout = document.getElementById('cutReadout');
    const scaleReadout = document.getElementById('scaleReadout');
    const formulaBox = document.getElementById('formulaBox');
    const explanationBox = document.getElementById('explanationBox');
    const captionBox = document.getElementById('captionBox');

    const stepBtn = document.getElementById('stepBtn');
    const resetBtn = document.getElementById('resetBtn');
    const downloadBtn = document.getElementById('downloadBtn');

    const PHI = (1 + Math.sqrt(5)) / 2;
    const SILVER = 1 + Math.sqrt(2);

    let manualDepth = null;

    function updateLabels() {
      baseWidthLabel.textContent = baseWidthEl.value;
      levelsLabel.textContent = manualDepth === null ? levelsEl.value : manualDepth;
    }

    function setInfo(family) {
      if (family === 'golden') {
        ratioReadout.textContent = `φ ≈ ${PHI.toFixed(6)}`;
        ruleReadout.textContent = 'R = 1 + 1/R';
        cutReadout.textContent = 'Remove 1 square';
        scaleReadout.textContent = `1/φ ≈ ${(1 / PHI).toFixed(6)}`;
        formulaBox.innerHTML = 'Golden:&nbsp; φ = 1 + 1/φ &nbsp;&nbsp; and so &nbsp;&nbsp; φ² = φ + 1';
        explanationBox.innerHTML = 'A golden rectangle has long side φ times the short side. Remove a square whose side equals the short side and the leftover rectangle has exactly the same proportion again.';
        captionBox.textContent = 'Golden case: one square is removed at each stage, and what remains is another golden rectangle scaled by 1/φ.';
      } else if (family === 'silver') {
        ratioReadout.textContent = `δ ≈ ${SILVER.toFixed(6)}`;
        ruleReadout.textContent = 'R = 2 + 1/R';
        cutReadout.textContent = 'Remove 2 squares';
        scaleReadout.textContent = `1/δ ≈ ${(1 / SILVER).toFixed(6)}`;
        formulaBox.innerHTML = 'Silver:&nbsp; δ = 2 + 1/δ &nbsp;&nbsp; and so &nbsp;&nbsp; δ² = 2δ + 1';
        explanationBox.innerHTML = 'A silver rectangle has long side δ times the short side. Remove two adjacent squares of side equal to the short side and the leftover rectangle again has the same silver proportion.';
        captionBox.textContent = 'Silver case: two equal squares are removed at each stage, and what remains is another silver rectangle scaled by 1/δ.';
      } else {
        ratioReadout.textContent = 'φ and δ side by side';
        ruleReadout.textContent = '1 + 1/R versus 2 + 1/R';
        cutReadout.textContent = '1 square versus 2 squares';
        scaleReadout.textContent = `1/φ ≈ ${(1 / PHI).toFixed(4)}, 1/δ ≈ ${(1 / SILVER).toFixed(4)}`;
        formulaBox.innerHTML = 'Golden: φ = 1 + 1/φ &nbsp;&nbsp; | &nbsp;&nbsp; Silver: δ = 2 + 1/δ';
        explanationBox.innerHTML = 'Golden self-similarity survives after removing one square. Silver self-similarity survives after removing two. The equations differ by the integer in front, and the geometry of the cut changes with it.';
        captionBox.textContent = 'Both are metallic recursions, but the visual mechanism differs: one-square persistence for φ, two-square persistence for δ.';
      }
    }

    function clearCanvas() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#05080d';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    }

    function drawLabel(text, x, y, color = '#a7b1c2') {
      ctx.save();
      ctx.fillStyle = color;
      ctx.font = '14px Arial';
      ctx.fillText(text, x, y);
      ctx.restore();
    }

    function drawRect(x, y, w, h, stroke = 'rgba(255,255,255,0.22)', lineWidth = 2) {
      ctx.save();
      ctx.strokeStyle = stroke;
      ctx.lineWidth = lineWidth;
      ctx.strokeRect(x, y, w, h);
      ctx.restore();
    }

    function fillRect(x, y, w, h, fill, stroke) {
      ctx.save();
      ctx.fillStyle = fill;
      ctx.strokeStyle = stroke;
      ctx.lineWidth = 1.4;
      ctx.fillRect(x, y, w, h);
      ctx.strokeRect(x, y, w, h);
      ctx.restore();
    }

    function drawTraceSegment(x1, y1, x2, y2) {
      ctx.save();
      ctx.strokeStyle = '#8ad6a2';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x2, y2);
      ctx.stroke();
      ctx.restore();
    }

    function drawGolden(x, y, shortSide, depth, guides, trace) {
      let s = shortSide;
      let L = PHI * s;
      let currentX = x;
      let currentY = y;

      for (let i = 0; i < depth; i++) {
        drawRect(currentX, currentY, L, s);

        fillRect(
          currentX,
          currentY,
          s,
          s,
          'rgba(244,201,107,0.28)',
          'rgba(244,201,107,0.9)'
        );

        const remX = currentX + s;
        const remY = currentY;
        const remW = L - s;
        const remH = s;

        drawRect(remX, remY, remW, remH, '#8fb8ff', 2.2);

        if (guides) {
          drawLabel(`square ${i + 1}`, currentX + 10, currentY + 18, '#f4c96b');
          drawLabel(`similar rectangle ${i + 1}`, remX + 10, remY + 18, '#8fb8ff');
        }

        if (trace) {
          drawTraceSegment(currentX + s / 2, currentY + s / 2, remX + remW / 2, remY + remH / 2);
        }

        currentX = remX;
        currentY = remY;
        L = remW;
        s = remH;
      }
    }

    function drawSilver(x, y, shortSide, depth, guides, trace) {
      let s = shortSide;
      let L = SILVER * s;
      let currentX = x;
      let currentY = y;

      for (let i = 0; i < depth; i++) {
        drawRect(currentX, currentY, L, s);

        fillRect(
          currentX,
          currentY,
          s,
          s,
          'rgba(244,201,107,0.28)',
          'rgba(244,201,107,0.9)'
        );
        fillRect(
          currentX + s,
          currentY,
          s,
          s,
          'rgba(244,201,107,0.28)',
          'rgba(244,201,107,0.9)'
        );

        const remX = currentX + 2 * s;
        const remY = currentY;
        const remW = L - 2 * s;
        const remH = s;

        drawRect(remX, remY, remW, remH, '#8fb8ff', 2.2);

        if (guides) {
          drawLabel(`2 squares ${i + 1}`, currentX + 10, currentY + 18, '#f4c96b');
          drawLabel(`similar rectangle ${i + 1}`, remX + 10, remY + 18, '#8fb8ff');
        }

        if (trace) {
          drawTraceSegment(currentX + s, currentY + s / 2, remX + remW / 2, remY + remH / 2);
        }

        currentX = remX;
        currentY = remY;
        L = remW;
        s = remH;
      }
    }

    function drawComparison(base, depth, guides, trace) {
      const leftX = 50;
      const topY = 180;
      drawGolden(leftX, topY, base, depth, guides, trace);
      drawLabel('Golden rectangle', leftX, 140, '#f4c96b');

      const rightX = leftX + PHI * base + 80;
      drawSilver(rightX, topY, base, depth, guides, trace);
      drawLabel('Silver rectangle', rightX, 140, '#f4c96b');
    }

    function draw() {
      clearCanvas();

      const family = familyEl.value;
      const base = parseFloat(baseWidthEl.value);
      const depth = manualDepth === null ? parseInt(levelsEl.value, 10) : manualDepth;
      const guides = showGuidesEl.value === 'on';
      const trace = showTraceEl.value === 'on';

      setInfo(family);

      if (family === 'golden') {
        drawGolden(90, 190, base, depth, guides, trace);
        drawLabel('Golden rectangle', 90, 150, '#f4c96b');
      } else if (family === 'silver') {
        drawSilver(90, 190, base, depth, guides, trace);
        drawLabel('Silver rectangle', 90, 150, '#f4c96b');
      } else {
        drawComparison(base * 0.72, depth, guides, trace);
      }
    }

    [familyEl, baseWidthEl, levelsEl, showGuidesEl, showTraceEl].forEach(el => {
      el.addEventListener('input', () => {
        if (el === levelsEl) manualDepth = null;
        updateLabels();
        draw();
      });
      el.addEventListener('change', () => {
        if (el === levelsEl) manualDepth = null;
        updateLabels();
        draw();
      });
    });

    stepBtn.addEventListener('click', () => {
      const maxDepth = parseInt(levelsEl.max, 10);
      const current = manualDepth === null ? parseInt(levelsEl.value, 10) : manualDepth;
      manualDepth = Math.min(current + 1, maxDepth);
      updateLabels();
      draw();
    });

    resetBtn.addEventListener('click', () => {
      manualDepth = 1;
      updateLabels();
      draw();
    });

    downloadBtn.addEventListener('click', () => {
      const link = document.createElement('a');
      link.download = 'golden_silver_rectangles.png';
      link.href = canvas.toDataURL('image/png');
      link.click();
    });

    manualDepth = parseInt(levelsEl.value, 10);
    updateLabels();
    draw();
  </script>
</body>
</html>
